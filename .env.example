# Local demo defaults only. Copy to `.env.local` or export variables in your shell.
# Do not put production credentials in this repo.

OPENOBSERVE_USER=admin@example.com
OPENOBSERVE_PASSWORD=change-me-openobserve-local
OPENOBSERVE_BASIC_AUTH_HEADER=Basic REPLACE_WITH_BASE64_USER_COLON_PASSWORD

