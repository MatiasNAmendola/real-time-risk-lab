# Local demo defaults only. Copy to `.env.local` or export variables in your shell.
# Do not put production credentials in this repo.

OPENOBSERVE_USER=admin@example.com
OPENOBSERVE_PASSWORD=change-me-openobserve-local
OPENOBSERVE_BASIC_AUTH_HEADER=Basic REPLACE_WITH_BASE64_USER_COLON_PASSWORD

# ── AWS mocks via Floci (ADR-0042) ──────────────────────────────────────────
# Single endpoint replaces MinIO/ElasticMQ/Moto/OpenBao. Floci listens on :4566.
# In compose:    FLOCI_ENDPOINT=http://floci:4566
# In k8s-local:  FLOCI_ENDPOINT=http://floci.aws-mocks.svc.cluster.local:4566
# From host:     FLOCI_ENDPOINT=http://localhost:4566
FLOCI_ENDPOINT=http://localhost:4566

# AWS dummy credentials — Floci accepts any value; 12-digit access keys are
# treated as account IDs for multi-account isolation (see Floci README).
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

ADMIN_TOKEN=change-me-admin-token
CONTROLLER_TO_USECASE_TOKEN=change-me-controller-usecase-token
USECASE_TO_REPOSITORY_TOKEN=change-me-usecase-repository-token
CONTROLLER_REPOSITORY_DENY_TOKEN=change-me-controller-deny-token

POC_DB_PASSWORD=change-me-db-password
POC_API_KEY=change-me-api-key
POC_SIGNING_KEY=change-me-signing-key
