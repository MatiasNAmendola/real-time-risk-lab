{
  "name": "@riskplatform/risk-client",
  "version": "1.0.0",
  "description": "Risk engine client SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest --testPathPattern=test/integration --testTimeout=30000"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.700.0",
    "eventsource": "^2.0.2",
    "kafkajs": "^2.2.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  }
}
