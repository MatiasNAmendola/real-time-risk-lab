<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <!-- Include traceparent + correlationId so OTel log bridge can correlate -->
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} [corrId=%X{correlationId}] [trace=%X{traceparent}] - %msg%n</pattern>
    </encoder>
  </appender>
  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
  <logger name="org.apache.kafka" level="WARN"/>
</configuration>
