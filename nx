nx_test() {
  local with_coverage=0
  local diagnose_on_fail=0
  local auto_fix=0
  local auto_fix_mode="--dry-run"
  local args=()
  for arg in "$@"; do
    case "$arg" in
      --coverage)        with_coverage=1 ;;
      --diagnose-on-fail) diagnose_on_fail=1 ;;
      --auto-fix)        auto_fix=1 ;;
      --apply)           auto_fix_mode="--apply" ;;
      --dry-run)         auto_fix_mode="--dry-run"; args+=("$arg") ;;
      --apply-only)      :  ;;
      # Convenience aliases that map to test-runner.py flags
      --with-infra-compose|--with-testcontainers|--with-infra)
        # Both flags translate to --auto-infra: the runner already knows
        # which groups need compose vs docker (testcontainers) from
        # test-groups.yaml `needs_infra: compose|docker`.
        args+=(--auto-infra) ;;
      *)                 args+=("$arg") ;;
    esac
  done

  if [[ $with_coverage -eq 1 ]]; then
    _info "[test] Running tests with coverage (jacocoAggregateReport)"
    "$REPO_ROOT/gradlew" -p "$REPO_ROOT" jacocoAggregateReport ${args[@]:+"${args[@]}"} || true

    local report_dir="$REPO_ROOT/build/reports/jacoco/aggregate"
    local report_xml="$report_dir/jacoco.xml"
    local report_html="$report_dir/index.html"

    if [[ -f "$report_xml" ]]; then
      local ts; ts="$(date -u +%Y-%m-%dT%H-%M-%SZ)"
      mkdir -p "$REPO_ROOT/out/coverage/$ts"

      # Print table to terminal
      python3 "$REPO_ROOT/.ai/scripts/coverage-summary.py" "$report_xml" \
        --html-path "out/coverage/$ts/html/index.html" \
        --md-path "out/coverage/$ts/summary.md"

      # Write Markdown summary
      python3 "$REPO_ROOT/.ai/scripts/coverage-summary.py" "$report_xml" \
        --markdown \
        --html-path "out/coverage/$ts/html/index.html" \
        > "$REPO_ROOT/out/coverage/$ts/summary.md"

      # Copy HTML report
      cp -r "$report_dir" "$REPO_ROOT/out/coverage/$ts/html"

      # Update latest symlink
      ln -sfn "$ts" "$REPO_ROOT/out/coverage/latest"

      echo ""
      echo "Coverage outputs:"
      echo "  HTML:     out/coverage/$ts/html/index.html"
      echo "  Markdown: out/coverage/$ts/summary.md"
    else
      _err "[test] jacoco.xml not generated. Aggregate report failed?"
      exit 1
    fi
    return
  fi

  local sub="${args[0]:-}"
  local rest=("${args[@]:1}")
  case "$sub" in
    "")
      # No subcommand: delegate to runner --list
      exec python3 "$REPO_ROOT/scripts/test-runner.py" --list
      ;;
    --list)
      exec python3 "$REPO_ROOT/scripts/test-runner.py" --list
      ;;
    --help|-h)
      usage_test
      exit 0
      ;;
    -*)
      # Pass through flags directly to runner (e.g. --composite, --dry-run, --auto-parallel)
      python3 "$REPO_ROOT/scripts/test-runner.py" "$sub" ${rest[@]:+"${rest[@]}"} || _test_post_hooks $?
      return
      ;;
    all|smoke|atdd-karate|atdd-cucumber|integration|architecture|unit)
      # Backward compatibility: map legacy subcommand names to runner --group
      local group_name="$sub"
      # Remap 'architecture' to 'arch' (runner canonical name)
      [ "$sub" = "architecture" ] && group_name="arch"
      python3 "$REPO_ROOT/scripts/test-runner.py" --group "$group_name" ${rest[@]:+"${rest[@]}"} \
        || _test_post_hooks $?
      return
      ;;
    *)
      # Treat as group or composite name
      python3 "$REPO_ROOT/scripts/test-runner.py" --group "$sub" ${rest[@]:+"${rest[@]}"} \
        || _test_post_hooks $?
      return
      ;;
  esac
}

# Post-test hooks: --diagnose-on-fail and --auto-fix
_test_post_hooks() {
  local exit_code="${1:-1}"
  if [[ $diagnose_on_fail -eq 1 && $exit_code -ne 0 ]]; then
    _warn "[test] Tests failed. Running diagnose..."
    python3 "$REPO_ROOT/.ai/scripts/debug-runner.py" diagnose || true
  fi
  if [[ $auto_fix -eq 1 ]]; then
    _info "[test] Running auto-fix dispatcher ($auto_fix_mode)..."
    python3 "$REPO_ROOT/.ai/scripts/auto-fix-dispatcher.py" $auto_fix_mode || true
  fi
  return $exit_code
}

nx_bench_k6() {
  # Args: <scenario> [--target X] [--vus N] [--duration T]
  # Or:   competition <scenario>
  if ! command -v k6 >/dev/null 2>&1; then
    _die "k6 not found in PATH. Install: brew install k6  (or run: ./scripts/setup/groups/70-optional.sh)"
  fi

  local first="${1:-}"
  shift || true

  if [ "$first" = "competition" ]; then
    local scenario="${1:-load}"; shift || true
    local ts; ts="$(date +%Y%m%dT%H%M%S)"
    local out_dir="$REPO_ROOT/out/k6-competition/$ts"
    mkdir -p "$out_dir"
    _info "k6 competition: scenario=$scenario  out=$out_dir"
    local targets=(bare monolith vertx-platform distributed)
    local fail=0
    for t in "${targets[@]}"; do
      _info "→ target=$t"
      local td="$out_dir/$t"
      mkdir -p "$td"
      if ! TARGET="$t" k6 run \
            --summary-export="$td/summary.json" \
            --out json="$td/raw.json" \
            "$REPO_ROOT/bench/k6/scenarios/${scenario}.js" \
            > "$td/stdout.txt" 2>&1; then
        _warn "  ✗ $t failed (see $td/stdout.txt)"
        fail=$((fail + 1))
      else
        _info "  ✓ $t"
      fi
    done
    # Build a tiny comparison.md
    {
      echo "# k6 competition — scenario=$scenario"
      echo
      echo "| target | p95_ms | p99_ms | error_rate | reqs |"
      echo "|---|---|---|---|---|"
      for t in "${targets[@]}"; do
        local s="$out_dir/$t/summary.json"
        if [ -f "$s" ]; then
          local p95 p99 err reqs
          p95=$(jq -r '.metrics.http_req_duration["p(95)"] // .metrics.http_req_duration.values["p(95)"] // "n/a"' "$s" 2>/dev/null)
          p99=$(jq -r '.metrics.http_req_duration["p(99)"] // .metrics.http_req_duration.values["p(99)"] // "n/a"' "$s" 2>/dev/null)
          err=$(jq -r '.metrics.http_req_failed.rate // .metrics.http_req_failed.values.rate // "n/a"' "$s" 2>/dev/null)
          reqs=$(jq -r '.metrics.http_reqs.count // .metrics.http_reqs.values.count // "n/a"' "$s" 2>/dev/null)
          echo "| $t | $p95 | $p99 | $err | $reqs |"
        else
          echo "| $t | FAILED | - | - | - |"
        fi
      done
    } > "$out_dir/comparison.md"
    ln -sfn "$ts" "$REPO_ROOT/out/k6-competition/latest"
    _info "Comparison written to $out_dir/comparison.md"
    [ "$fail" -eq 0 ] || return 1
    return 0
  fi

  local scenario="$first"
  case "$scenario" in
    smoke|load|stress|spike|soak) ;;
    ""|--help|-h) _die "Usage: ./nx bench k6 <smoke|load|stress|spike|soak> [--target SVC] [--vus N] [--duration T]" ;;
    *) _die "Unknown k6 scenario: $scenario (valid: smoke|load|stress|spike|soak)" ;;
  esac

  local target="distributed"
  local vus="" duration=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --target)   target="$2";   shift 2 ;;
      --vus)      vus="$2";      shift 2 ;;
      --duration) duration="$2"; shift 2 ;;
      *) _die "Unknown k6 arg: $1" ;;
    esac
  done

  local ts; ts="$(date +%Y%m%dT%H%M%S)"
  local out_dir="$REPO_ROOT/out/k6/$scenario/$ts"
  mkdir -p "$out_dir"

  local args=(run)
  args+=(--summary-export="$out_dir/summary.json")
  args+=(--out "json=$out_dir/raw.json")
  if [ -n "${K6_PROMETHEUS_RW_SERVER_URL:-}" ]; then
    args+=(-o experimental-prometheus-rw)
    _info "  → also pushing to Prometheus RW: $K6_PROMETHEUS_RW_SERVER_URL"
  fi
  [ -n "$vus" ]      && args+=(-e "VUS=$vus")
  [ -n "$duration" ] && args+=(-e "DURATION=$duration")
  args+=("$REPO_ROOT/bench/k6/scenarios/${scenario}.js")

  _info "k6 run: scenario=$scenario target=$target out=$out_dir"
  ln -sfn "$ts" "$REPO_ROOT/out/k6/$scenario/latest"
  TARGET="$target" k6 "${args[@]}"
}

