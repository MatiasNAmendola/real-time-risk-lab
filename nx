# ---------------------------------------------------------------------------
# Require a script to exist before delegating
# ---------------------------------------------------------------------------
_require_script() {
  local path="$1"
  if [ ! -f "$path" ]; then
    _die "Script not found: $path"
  fi
  if [ ! -x "$path" ]; then
    chmod +x "$path"
  fi
}

# ---------------------------------------------------------------------------
# Subcommand implementations
# ---------------------------------------------------------------------------

nx_setup() {
  local script="$REPO_ROOT/setup.sh"
  _require_script "$script"
  _info "Delegating to setup.sh $*"
  exec "$script" "$@"
}

nx_up() {
  local mode="${1:-vertx}"
  shift || true
  case "$mode" in
    infra)
      _info "Bringing up shared infra (no apps)..."
      exec docker compose -f "$REPO_ROOT/compose/docker-compose.yml" up -d "$@"
      ;;
    vertx)
      local script="$REPO_ROOT/poc/java-vertx-distributed/scripts/up.sh"
      if [ -f "$script" ]; then
        _require_script "$script"
        _info "Bringing up infra + java-vertx-distributed..."
        exec "$script" "$@"
      else
        _info "Running docker compose up (fallback)..."
        REPO_ROOT="$REPO_ROOT" exec docker compose \
          -f "$REPO_ROOT/compose/docker-compose.yml" \
          -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
          up -d "$@"
      fi
      ;;
    monolith)
      _info "Bringing up infra + java-monolith..."
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/java-monolith/compose.override.yml" \
        up -d "$@"
      ;;
    vertx-platform)
      # vertx-risk-platform: 3-pod HTTP+tokens PoC (ports 8180/8181/8182, no data-net)
      _info "Bringing up infra + vertx-risk-platform..."
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/vertx-risk-platform/compose.override.yml" \
        up -d "$@"
      ;;
    all)
      _info "Bringing up infra + vertx + monolith + vertx-platform..."
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
        -f "$REPO_ROOT/poc/java-monolith/compose.override.yml" \
        -f "$REPO_ROOT/poc/vertx-risk-platform/compose.override.yml" \
        up -d "$@"
      ;;
    compose)
      # backward compat alias
      _info "Redirecting 'compose' -> 'vertx' (see: ./nx help)"
      nx_up vertx "$@"
      ;;
    k8s)
      local script="$REPO_ROOT/poc/k8s-local/scripts/up.sh"
      _require_script "$script"
      _info "Bringing up k8s cluster..."
      exec "$script" "$@"
      ;;
    --help|-h)
      printf 'Usage: ./nx up [infra|vertx|vertx-platform|monolith|all|k8s] [--orbstack|--k3d]\n'
      exit 0
      ;;
    *)
      _die "Unknown target: $mode. Use: infra, vertx, vertx-platform, monolith, all, k8s"
      ;;
  esac
}

nx_down() {
  local mode="${1:-vertx}"
  shift || true
  case "$mode" in
    infra)
      _info "Tearing down shared infra..."
      exec docker compose -f "$REPO_ROOT/compose/docker-compose.yml" down "$@"
      ;;
    vertx)
      local script="$REPO_ROOT/poc/java-vertx-distributed/scripts/down.sh"
      if [ -f "$script" ]; then
        _require_script "$script"
        exec "$script" "$@"
      else
        REPO_ROOT="$REPO_ROOT" exec docker compose \
          -f "$REPO_ROOT/compose/docker-compose.yml" \
          -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
          down "$@"
      fi
      ;;
    monolith)
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/java-monolith/compose.override.yml" \
        down "$@"
      ;;
    all)
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
        -f "$REPO_ROOT/poc/java-monolith/compose.override.yml" \
        down "$@"
      ;;
    compose)
      # backward compat alias
      nx_down vertx "$@"
      ;;
    k8s)
      local script="$REPO_ROOT/poc/k8s-local/scripts/down.sh"
      _require_script "$script"
      exec "$script" "$@"
      ;;
    --help|-h)
      printf 'Usage: ./nx down [infra|vertx|monolith|all|k8s] [--cleanup-k8s]\n'
      exit 0
      ;;
    *)
      _die "Unknown target: $mode. Use: infra, vertx, monolith, all, k8s"
      ;;
  esac
}

nx_status() {
  _info "Docker containers:"
  docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || _warn "docker not available"
  local k8s_script="$REPO_ROOT/poc/k8s-local/scripts/status.sh"
  if [ -f "$k8s_script" ]; then
    _info "K8s pods:"
    bash "$k8s_script" 2>/dev/null || true
  fi
}

nx_logs() {
  local service="${1:-}"
  if [ -z "$service" ]; then
    _die "Usage: ./nx logs <service>"
  fi
  _info "Tailing logs for: $service"
  docker logs -f "$service" 2>/dev/null || _die "Service not found or docker unavailable: $service"
}

nx_build() {
  _info "Running ./gradlew clean build..."
  exec "$REPO_ROOT/gradlew" -p "$REPO_ROOT" clean build "$@"
}

nx_run() {
  local target="${1:-}"
  shift || true
  case "$target" in
    risk-engine)
      local script="$REPO_ROOT/poc/java-risk-engine/scripts/run-http.sh"
      _require_script "$script"
      _info "Starting risk-engine HTTP server..."
      exec "$script" "$@"
      ;;
    java-monolith)
      local script="$REPO_ROOT/poc/java-monolith/scripts/run.sh"
      _require_script "$script"
      _info "Starting java-monolith on port 8090..."
      exec "$script" "$@"
      ;;
    vertx)
      local script="$REPO_ROOT/poc/java-vertx-distributed/scripts/up.sh"
      if [ -f "$script" ]; then
        _require_script "$script"
        _info "Starting Vert.x distributed stack..."
        exec "$script" "$@"
      else
        REPO_ROOT="$REPO_ROOT" exec docker compose \
          -f "$REPO_ROOT/compose/docker-compose.yml" \
          -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
          up "$@"
      fi
      ;;
    vertx-platform)
      # vertx-risk-platform: 3-pod HTTP + token-based permissions PoC
      local vrp_jar="$REPO_ROOT/poc/vertx-risk-platform/build/libs/vertx-risk-platform.jar"
      if [ ! -f "$vrp_jar" ]; then
        _info "Building vertx-risk-platform fat-jar..."
        "$REPO_ROOT/gradlew" -p "$REPO_ROOT" :poc:vertx-risk-platform:shadowJar \
          || _die "Build failed. Run: ./gradlew :poc:vertx-risk-platform:shadowJar"
      fi
      _info "Starting vertx-risk-platform pods (controller=8080, usecase=8081, repository=8082)..."
      "$REPO_ROOT/poc/vertx-risk-platform/scripts/run-local-pods.sh" "$@"
      ;;
    k8s)
      local up_script="$REPO_ROOT/poc/k8s-local/scripts/up.sh"
      _require_script "$up_script"
      _info "Bringing up k8s + helm install..."
      exec "$up_script" "$@"
      ;;
    --help|-h)
      printf 'Usage: ./nx run <risk-engine|vertx|vertx-platform|java-monolith|k8s> [args...]\n'
      exit 0
      ;;
    "")
      _die "Usage: ./nx run <risk-engine|vertx|vertx-platform|java-monolith|k8s>"
      ;;
    *)
      _die "Unknown run target: $target. Use: risk-engine, vertx, vertx-platform, java-monolith, k8s"
      ;;
  esac
}

nx_test() {
  local with_coverage=0
  local diagnose_on_fail=0
  local auto_fix=0
  local auto_fix_mode="--dry-run"
  local args=()
  for arg in "$@"; do
    case "$arg" in
      --coverage)        with_coverage=1 ;;
      --diagnose-on-fail) diagnose_on_fail=1 ;;
      --auto-fix)        auto_fix=1 ;;
      --apply)           auto_fix_mode="--apply" ;;
      --dry-run)         auto_fix_mode="--dry-run"; args+=("$arg") ;;
      --apply-only)      :  ;;
      # Convenience aliases that map to test-runner.py flags
      --with-infra-compose|--with-testcontainers|--with-infra)
        # Both flags translate to --auto-infra: the runner already knows
        # which groups need compose vs docker (testcontainers) from
        # test-groups.yaml `needs_infra: compose|docker`.
        args+=(--auto-infra) ;;
      *)                 args+=("$arg") ;;
    esac
  done

  if [[ $with_coverage -eq 1 ]]; then
    _info "[test] Running tests with coverage (jacocoAggregateReport)"
    "$REPO_ROOT/gradlew" -p "$REPO_ROOT" jacocoAggregateReport ${args[@]:+"${args[@]}"} || true

    local report_dir="$REPO_ROOT/build/reports/jacoco/aggregate"
    local report_xml="$report_dir/jacoco.xml"
    local report_html="$report_dir/index.html"

    if [[ -f "$report_xml" ]]; then
      local ts; ts="$(date -u +%Y-%m-%dT%H-%M-%SZ)"
      mkdir -p "$REPO_ROOT/out/coverage/$ts"

      # Print table to terminal
      python3 "$REPO_ROOT/.ai/scripts/coverage-summary.py" "$report_xml" \
        --html-path "out/coverage/$ts/html/index.html" \
        --md-path "out/coverage/$ts/summary.md"

      # Write Markdown summary
      python3 "$REPO_ROOT/.ai/scripts/coverage-summary.py" "$report_xml" \
        --markdown \
        --html-path "out/coverage/$ts/html/index.html" \
        > "$REPO_ROOT/out/coverage/$ts/summary.md"

      # Copy HTML report
      cp -r "$report_dir" "$REPO_ROOT/out/coverage/$ts/html"

      # Update latest symlink
      ln -sfn "$ts" "$REPO_ROOT/out/coverage/latest"

      echo ""
      echo "Coverage outputs:"
      echo "  HTML:     out/coverage/$ts/html/index.html"
      echo "  Markdown: out/coverage/$ts/summary.md"
    else
      _err "[test] jacoco.xml not generated. Aggregate report failed?"
      exit 1
    fi
    return
  fi

  local sub="${args[0]:-}"
  local rest=("${args[@]:1}")
  case "$sub" in
    "")
      # No subcommand: delegate to runner --list
      exec python3 "$REPO_ROOT/scripts/test-runner.py" --list
      ;;
    --list)
      exec python3 "$REPO_ROOT/scripts/test-runner.py" --list
      ;;
    --help|-h)
      usage_test
      exit 0
      ;;
    -*)
      # Pass through flags directly to runner (e.g. --composite, --dry-run, --auto-parallel)
      python3 "$REPO_ROOT/scripts/test-runner.py" "$sub" ${rest[@]:+"${rest[@]}"} || _test_post_hooks $?
      return
      ;;
    all|smoke|atdd-karate|atdd-cucumber|integration|architecture|unit)
      # Backward compatibility: map legacy subcommand names to runner --group
      local group_name="$sub"
      # Remap 'architecture' to 'arch' (runner canonical name)
      [ "$sub" = "architecture" ] && group_name="arch"
      python3 "$REPO_ROOT/scripts/test-runner.py" --group "$group_name" ${rest[@]:+"${rest[@]}"} \
        || _test_post_hooks $?
      return
      ;;
    *)
      # Treat as group or composite name
      python3 "$REPO_ROOT/scripts/test-runner.py" --group "$sub" ${rest[@]:+"${rest[@]}"} \
        || _test_post_hooks $?
      return
      ;;
  esac
}

# Post-test hooks: --diagnose-on-fail and --auto-fix
_test_post_hooks() {
  local exit_code="${1:-1}"
  if [[ $diagnose_on_fail -eq 1 && $exit_code -ne 0 ]]; then
    _warn "[test] Tests failed. Running diagnose..."
    python3 "$REPO_ROOT/.ai/scripts/debug-runner.py" diagnose || true
  fi
  if [[ $auto_fix -eq 1 ]]; then
    _info "[test] Running auto-fix dispatcher ($auto_fix_mode)..."
    python3 "$REPO_ROOT/.ai/scripts/auto-fix-dispatcher.py" $auto_fix_mode || true
  fi
  return $exit_code
}

nx_bench() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    inproc)
      local script="$REPO_ROOT/bench/scripts/run-inprocess.sh"
      _require_script "$script"
      _info "Running JMH in-process benchmark..."
      exec "$script" "$@"
      ;;
    distributed)
      local script="$REPO_ROOT/bench/scripts/run-distributed.sh"
      if [ ! -f "$script" ]; then
        _die "Distributed bench script not found: $script"
      fi
      _require_script "$script"
      _info "Running distributed HTTP benchmark..."
      exec "$script" "$@"
      ;;
    competition)
      _info "Running competition benchmark (inproc + distributed)..."
      local inproc="$REPO_ROOT/bench/scripts/run-inprocess.sh"
      _require_script "$inproc"
      bash "$inproc" "$@"
      local dist="$REPO_ROOT/bench/scripts/run-distributed.sh"
      if [ -f "$dist" ]; then
        bash "$dist" "$@"
      else
        _warn "Distributed bench script not found, skipping: $dist"
      fi
      ;;
    --help|-h|"")
      usage_bench
      exit 0
      ;;
    *)
      _die "Unknown bench target: $sub. Use: inproc, distributed, competition"
      ;;
  esac
}

nx_demo() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    rest)
      # Parse demo-rest specific flags BEFORE forwarding to demo.sh.
      # demo.sh accepts only an optional positional BASE_URL, so any
      # --amount / --customer flags would otherwise leak into BASE_URL or
      # later get passed to curl as bogus options.
      local base_url=""
      local amount=""
      local customer=""
      local passthrough=()
      while [ $# -gt 0 ]; do
        case "$1" in
          --amount)    amount="${2:-}";  shift 2 ;;
          --amount=*)  amount="${1#*=}"; shift ;;
          --customer)  customer="${2:-}"; shift 2 ;;
          --customer=*) customer="${1#*=}"; shift ;;
          --base-url)  base_url="${2:-}"; shift 2 ;;
          --base-url=*) base_url="${1#*=}"; shift ;;
          --) shift; passthrough+=("$@"); break ;;
          -*) passthrough+=("$1"); shift ;;
          *)
            # First positional = BASE_URL (matches demo.sh contract)
            if [ -z "$base_url" ]; then base_url="$1"; else passthrough+=("$1"); fi
            shift
            ;;
        esac
      done
      base_url="${base_url:-http://localhost:8080}"

      # If the user asked for a custom amount/customer, do a single targeted
      # POST instead of running the full 6-flow scripted demo (which uses
      # hardcoded payloads). Otherwise fall back to the canonical demo.sh.
      if [ -n "$amount" ] || [ -n "$customer" ]; then
        local cust="${customer:-cust-demo}"
        local amt="${amount:-150000}"
        local tx_id="tx-$(date +%s)-$$"
        local idem_key="idem-${tx_id}"
        local corr_id="corr-${tx_id}"
        local payload
        payload=$(printf '{"transactionId":"%s","customerId":"%s","amountCents":%s,"correlationId":"%s","idempotencyKey":"%s"}' \
          "$tx_id" "$cust" "$amt" "$corr_id" "$idem_key")
        _info "POST $base_url/risk  payload=$payload"
        exec curl -sS -w "\nHTTP %{http_code}\n" \
          -X POST "$base_url/risk" \
          -H "Content-Type: application/json" \
          -d "$payload" \
          ${passthrough[@]:+"${passthrough[@]}"}
      fi

      local script="$REPO_ROOT/poc/java-vertx-distributed/scripts/demo.sh"
      if [ ! -f "$script" ]; then
        script="$REPO_ROOT/poc/java-risk-engine/scripts/test.sh"
      fi
      _require_script "$script"
      _info "Running REST demo (BASE_URL=$base_url)..."
      exec "$script" "$base_url" ${passthrough[@]:+"${passthrough[@]}"}
      ;;
    websocket)
      _info "Connecting to WebSocket endpoint..."
      command -v wscat >/dev/null 2>&1 || _die "wscat not found. Install: npm install -g wscat"
      exec wscat -c "ws://localhost:8080/risk/ws" "$@"
      ;;
    sse)
      _info "Consuming SSE stream..."
      exec curl -N -H "Accept: text/event-stream" "http://localhost:8080/risk/events" "$@"
      ;;
    webhook)
      local script="$REPO_ROOT/poc/java-vertx-distributed/scripts/demo.sh"
      if [ -f "$script" ]; then
        _require_script "$script"
        exec "$script" webhook "$@"
      else
        _info "Registering webhook and triggering..."
        curl -s -X POST http://localhost:8080/webhooks \
          -H 'Content-Type: application/json' \
          -d '{"url":"http://host.docker.internal:9999/hook","events":["risk.decision"]}' \
          | cat
      fi
      ;;
    kafka)
      _info "Producing Kafka message..."
      docker exec -it redpanda rpk topic produce risk-transactions --brokers localhost:9092 <<'EOF'
{"transactionId":"demo-001","customerId":"cust-demo","amountCents":150000,"correlationId":"corr-demo-001","idempotencyKey":"idem-demo-001"}
EOF
      _info "Consuming Kafka message..."
      docker exec -it redpanda rpk topic consume risk-transactions --brokers localhost:9092 -n 1
      ;;
    --help|-h|"")
      usage_demo
      exit 0
      ;;
    *)
      _die "Unknown demo target: $sub. Use: rest, websocket, sse, webhook, kafka"
      ;;
  esac
}

nx_dashboard() {
  local action="${1:-up}"
  shift || true
  local compose_file="$REPO_ROOT/dashboard/docker-compose.yml"
  local start_script="$REPO_ROOT/dashboard/scripts/start.sh"
  case "$action" in
    up)
      if [ -f "$start_script" ]; then
        _require_script "$start_script"
        _info "Starting dashboard..."
        exec "$start_script" "$@"
      elif [ -f "$compose_file" ]; then
        _info "Starting Homer dashboard..."
        exec docker compose -f "$compose_file" up -d "$@"
      else
        _die "Dashboard compose file not found: $compose_file"
      fi
      ;;
    down)
      if [ -f "$compose_file" ]; then
        _info "Stopping dashboard..."
        exec docker compose -f "$compose_file" down "$@"
      else
        _die "Dashboard compose file not found: $compose_file"
      fi
      ;;
    --help|-h)
      printf 'Usage: ./nx dashboard [up|down]\n'
      printf '  up    Start Homer dashboard (localhost:8888)\n'
      printf '  down  Stop Homer dashboard\n'
      exit 0
      ;;
    *)
      _die "Unknown dashboard action: $action. Use: up, down"
      ;;
  esac
}

nx_admin() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    rules)
      local action="${1:-list}"
      shift || true
      _info "Admin rules $action..."
      case "$action" in
        list)
          curl -s "http://localhost:8080/admin/rules" | cat
          ;;
        reload)
          curl -s -X POST "http://localhost:8080/admin/rules/reload" | cat
          ;;
        test)
          curl -s -X POST "http://localhost:8080/admin/rules/test" \
            -H "Content-Type: application/json" \
            -d '{"transactionId":"test-001","customerId":"cust-test","amountCents":100000}' | cat
          ;;
        *)
          _die "Unknown rules action: $action. Use: list, reload, test"
          ;;
      esac
      ;;
    --help|-h|"")
      printf 'Usage: ./nx admin rules [list|reload|test] [--config path]\n'
      exit 0
      ;;
    *)
      _die "Unknown admin subcommand: $sub. Use: rules"
      ;;
  esac
}

nx_failures() {
  local script="$REPO_ROOT/.ai/scripts/failures-aggregator.py"
  _require_script "$script"
  _info "Aggregating test failures..."
  exec python3 "$script" "$@"
}

nx_logs() {
  # If first arg looks like a service name (no --), forward to docker logs (legacy)
  # If first arg is a flag, use debug-runner
  local first="${1:-}"
  if [[ -z "$first" || "$first" == --* ]]; then
    local script="$REPO_ROOT/.ai/scripts/debug-runner.py"
    _require_script "$script"
    exec python3 "$script" logs "$@"
  else
    # Legacy behavior: ./nx logs <service>
    _info "Tailing logs for: $first"
    docker logs -f "$first" 2>/dev/null || _die "Service not found or docker unavailable: $first"
  fi
}

nx_debug() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    diagnose|snapshot|trace|probe)
      local script="$REPO_ROOT/.ai/scripts/debug-runner.py"
      _require_script "$script"
      exec python3 "$script" "$sub" "$@"
      ;;
    --help|-h|"")
      printf 'Usage: ./nx debug {diagnose|snapshot|trace|probe} [args...]\n'
      printf '  diagnose   heuristic root cause analysis\n'
      printf '  snapshot   forensic bundle to out/debug/<ts>/\n'
      printf '  trace ID   OpenObserve trace lookup by trace ID\n'
      printf '  probe      DNS connectivity probe between services\n'
      exit 0
      ;;
    *)
      _die "Unknown debug sub-command: $sub. Use: diagnose, snapshot, trace, probe"
      ;;
  esac
}

nx_audit() {
  case "${1:-}" in
    failures)
      shift
      _info "[audit] Running failures aggregator + diagnose..."
      python3 "$REPO_ROOT/.ai/scripts/failures-aggregator.py" "$@" || true
      _info "[audit] Running diagnose..."
      python3 "$REPO_ROOT/.ai/scripts/debug-runner.py" diagnose || true
      ;;
    coverage)
      _info "[audit] Generating jacocoAggregateReport..."
      "$REPO_ROOT/gradlew" -p "$REPO_ROOT" jacocoAggregateReport
      local report="$REPO_ROOT/build/reports/jacoco/aggregate/index.html"
      if [[ -f "$report" ]]; then
        open "$report" 2>/dev/null || \
          xdg-open "$report" 2>/dev/null || \
          _ok "Open: $report"
      else
        _warn "Report not found: $report"
      fi
      ;;
    consistency)
      shift
      local con_script="$REPO_ROOT/.ai/scripts/consistency-auditor.py"
      if [ ! -f "$con_script" ]; then
        _die "Consistency auditor not found: $con_script"
      fi
      local ts
      ts="$(date '+%Y%m%dT%H%M%S')"
      local out_dir="$REPO_ROOT/out/audit-consistency/$ts"
      mkdir -p "$out_dir"
      _info "Running consistency audit -> $out_dir"
      python3 "$con_script" all --strict --out-dir "$out_dir" "$@"
      _ok "Report: $out_dir/summary.md"
      ;;
    confidentiality)
      shift
      local conf_script="$REPO_ROOT/.ai/scripts/confidentiality-scanner.py"
      if [ ! -f "$conf_script" ]; then
        _die "Confidentiality scanner not found: $conf_script"
      fi
      _info "Running confidentiality scan..."
      python3 "$conf_script" "$@"
      local rc=$?
      if [ $rc -eq 0 ]; then
        _ok "Confidentiality scan passed."
      else
        _warn "Confidentiality scan found prohibited term(s). Review output above."
      fi
      exit $rc
      ;;
    codebase-access)
      shift
      local ts
      ts="$(date -u +%Y-%m-%dT%H-%M-%SZ)"
      local out_dir="$REPO_ROOT/out/codebase-access-audit/$ts"
      _info "Running codebase access audit -> $out_dir"
      python3 "$REPO_ROOT/.ai/scripts/codebase-access-auditor.py" \
        --out-dir "$out_dir" \
        "$@"
      _ok "Report: $out_dir/summary.md"
      ;;
    *)
      local script="$REPO_ROOT/.ai/scripts/coverage-audit.py"
      if [ ! -f "$script" ]; then
        _die "Audit script not found: $script"
      fi
      _info "Running coverage audit: $*"
      exec python3 "$script" "$@"
      ;;
  esac
}

nx_completion() {
  local shell="${1:-bash}"
  case "$shell" in
    bash)
      cat "$REPO_ROOT/scripts/nx-completion.bash"
      ;;
    *)
      _die "Only bash completion is supported. Usage: ./nx completion bash > ~/.bash_completion.d/nx"
      ;;
  esac
}

nx_scrub() {
  _info "Running secrets/PII scrub..."
  local scrub_script="$REPO_ROOT/.ai/scripts/scrub.sh"
  if [ -f "$scrub_script" ]; then
    _require_script "$scrub_script"
    exec "$scrub_script" "$@"
  fi
  # Fallback: grep for common patterns
  local found=0
  _info "Scanning for potential secrets/PII patterns..."
  if grep -rn \
    -e 'password\s*=\s*[^$]' \
    -e 'secret\s*=\s*[^$]' \
    -e 'api_key\s*=\s*[^$]' \
    --include="*.properties" \
    --include="*.env" \
    --include="*.yaml" \
    --include="*.yml" \
    --exclude-dir=".git" \
    --exclude-dir="build" \
    --exclude-dir="node_modules" \
    "$REPO_ROOT" 2>/dev/null; then
    found=1
  fi
  if [ "$found" -eq 0 ]; then
    _ok "No obvious secrets/PII patterns found."
  else
    _warn "Review the above matches."
  fi
}

nx_version() {
  printf 'nx version %s\n' "$NX_VERSION"
}

# ---------------------------------------------------------------------------
# Help dispatcher
# ---------------------------------------------------------------------------
nx_help() {
  local topic="${1:-}"
  case "$topic" in
    test)     usage_test ;;
    bench)    usage_bench ;;
    demo)     usage_demo ;;
    "")       usage ;;
    *)        usage ;;
  esac
  exit 0
}

# ---------------------------------------------------------------------------
# Main dispatcher
# ---------------------------------------------------------------------------
main() {
  if [ $# -eq 0 ]; then
    usage
    exit 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    setup)         nx_setup "$@" ;;
    up)            nx_up "$@" ;;
    down)          nx_down "$@" ;;
    status)        nx_status "$@" ;;
    logs)          nx_logs "$@" ;;
    build)         nx_build "$@" ;;
    run)           nx_run "$@" ;;
    test)          nx_test "$@" ;;
    bench)         nx_bench "$@" ;;
    demo)          nx_demo "$@" ;;
    dashboard)     nx_dashboard "$@" ;;
    admin)         nx_admin "$@" ;;
    audit)         nx_audit "$@" ;;
    scrub)         nx_scrub "$@" ;;
    failures)      nx_failures "$@" ;;
    debug)         nx_debug "$@" ;;
    completion)    nx_completion "$@" ;;
    help)          nx_help "$@" ;;
    version)       nx_version ;;
    --help|-h)     usage; exit 0 ;;
    --version|-v)  nx_version ;;
    *)
      _err "Unknown command: $cmd"
      printf '\nRun ./nx help for available commands.\n' >&2
      exit 1
      ;;
  esac
}

main "$@"
