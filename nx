#!/usr/bin/env bash
# nx — master CLI for the Risk Decision Platform project
#
# Compatible with bash 3.2 (macOS default). Auto-reexecs under brew bash when available.
# Usage: ./nx <command> [subcommand] [args...]

set -euo pipefail

NX_VERSION="0.1.0"
REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"

# ---------------------------------------------------------------------------
# Bash version guard — reexec under brew bash 4+ if available
# ---------------------------------------------------------------------------
if [ "${BASH_VERSINFO[0]}" -lt 4 ]; then
  BREW_BASH=""
  if command -v brew >/dev/null 2>&1; then
    BREW_BASH="$(brew --prefix 2>/dev/null)/bin/bash"
  fi
  if [ -n "$BREW_BASH" ] && [ -x "$BREW_BASH" ]; then
    exec "$BREW_BASH" "$0" "$@"
  fi
fi

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------
_info()    { printf '[nx] %s\n' "$*"; }
_ok()      { printf '[nx] OK: %s\n' "$*"; }
_warn()    { printf '[nx] WARN: %s\n' "$*" >&2; }
_err()     { printf '[nx] ERROR: %s\n' "$*" >&2; }
_die()     { _err "$*"; exit 1; }

