nx_scrub() {
  _info "Running secrets/PII scrub..."
  local scrub_script="$REPO_ROOT/.ai/scripts/scrub.sh"
  if [ -f "$scrub_script" ]; then
    _require_script "$scrub_script"
    exec "$scrub_script" "$@"
  fi
  # Fallback: grep for common patterns
  local found=0
  _info "Scanning for potential secrets/PII patterns..."
  if grep -rn \
    -e 'password\s*=\s*[^$]' \
    -e 'secret\s*=\s*[^$]' \
    -e 'api_key\s*=\s*[^$]' \
    --include="*.properties" \
    --include="*.env" \
    --include="*.yaml" \
    --include="*.yml" \
    --exclude-dir=".git" \
    --exclude-dir="build" \
    --exclude-dir="node_modules" \
    "$REPO_ROOT" 2>/dev/null; then
    found=1
  fi
  if [ "$found" -eq 0 ]; then
    _ok "No obvious secrets/PII patterns found."
  else
    _warn "Review the above matches."
  fi
}

nx_version() {
  printf 'nx version %s\n' "$NX_VERSION"
}

# ---------------------------------------------------------------------------
# Help dispatcher
# ---------------------------------------------------------------------------
nx_help() {
  local topic="${1:-}"
  case "$topic" in
    test)     usage_test ;;
    bench)    usage_bench ;;
    demo)     usage_demo ;;
    "")       usage ;;
    *)        usage ;;
  esac
  exit 0
}

# ---------------------------------------------------------------------------
# Main dispatcher
# ---------------------------------------------------------------------------
main() {
  if [ $# -eq 0 ]; then
    usage
    exit 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    setup)         nx_setup "$@" ;;
    up)            nx_up "$@" ;;
    down)          nx_down "$@" ;;
    status)        nx_status "$@" ;;
    logs)          nx_logs "$@" ;;
    build)         nx_build "$@" ;;
    run)           nx_run "$@" ;;
    test)          nx_test "$@" ;;
    bench)         nx_bench "$@" ;;
    demo)          nx_demo "$@" ;;
    dashboard)     nx_dashboard "$@" ;;
    admin)         nx_admin "$@" ;;
    audit)         nx_audit "$@" ;;
    scrub)         nx_scrub "$@" ;;
    failures)      nx_failures "$@" ;;
    debug)         nx_debug "$@" ;;
    completion)    nx_completion "$@" ;;
    help)          nx_help "$@" ;;
    version)       nx_version ;;
    --help|-h)     usage; exit 0 ;;
    --version|-v)  nx_version ;;
    *)
      _err "Unknown command: $cmd"
      printf '\nRun ./nx help for available commands.\n' >&2
      exit 1
      ;;
  esac
}

main "$@"
