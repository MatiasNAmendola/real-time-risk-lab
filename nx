# ---------------------------------------------------------------------------
# Require a script to exist before delegating
# ---------------------------------------------------------------------------
_require_script() {
  local path="$1"
  if [ ! -f "$path" ]; then
    _die "Script not found: $path"
  fi
  if [ ! -x "$path" ]; then
    chmod +x "$path"
  fi
}

# ---------------------------------------------------------------------------
# Subcommand implementations
# ---------------------------------------------------------------------------

nx_setup() {
  local script="$REPO_ROOT/setup.sh"
  _require_script "$script"
  _info "Delegating to setup.sh $*"
  exec "$script" "$@"
}

nx_up() {
  local mode="${1:-vertx}"
  shift || true
  case "$mode" in
    infra)
      _info "Bringing up shared infra (no apps)..."
      exec docker compose -f "$REPO_ROOT/compose/docker-compose.yml" up -d "$@"
      ;;
    vertx)
      local script="$REPO_ROOT/poc/java-vertx-distributed/scripts/up.sh"
      if [ -f "$script" ]; then
        _require_script "$script"
        _info "Bringing up infra + java-vertx-distributed..."
        exec "$script" "$@"
      else
        _info "Running docker compose up (fallback)..."
        REPO_ROOT="$REPO_ROOT" exec docker compose \
          -f "$REPO_ROOT/compose/docker-compose.yml" \
          -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
          up -d "$@"
      fi
      ;;
    monolith)
      _info "Bringing up infra + java-monolith..."
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/java-monolith/compose.override.yml" \
        up -d "$@"
      ;;
    vertx-platform)
      # vertx-risk-platform: 3-pod HTTP+tokens PoC (ports 8180/8181/8182, no data-net)
      _info "Bringing up infra + vertx-risk-platform..."
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/vertx-risk-platform/compose.override.yml" \
        up -d "$@"
      ;;
    all)
      _info "Bringing up infra + vertx + monolith + vertx-platform..."
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
        -f "$REPO_ROOT/poc/java-monolith/compose.override.yml" \
        -f "$REPO_ROOT/poc/vertx-risk-platform/compose.override.yml" \
        up -d "$@"
      ;;
    compose)
      # backward compat alias
      _info "Redirecting 'compose' -> 'vertx' (see: ./nx help)"
      nx_up vertx "$@"
      ;;
    k8s)
      local script="$REPO_ROOT/poc/k8s-local/scripts/up.sh"
      _require_script "$script"
      _info "Bringing up k8s cluster..."
      exec "$script" "$@"
      ;;
    --help|-h)
      printf 'Usage: ./nx up [infra|vertx|vertx-platform|monolith|all|k8s] [--orbstack|--k3d]\n'
      exit 0
      ;;
    *)
      _die "Unknown target: $mode. Use: infra, vertx, vertx-platform, monolith, all, k8s"
      ;;
  esac
}

nx_down() {
  local mode="${1:-vertx}"
  shift || true
  case "$mode" in
    infra)
      _info "Tearing down shared infra..."
      exec docker compose -f "$REPO_ROOT/compose/docker-compose.yml" down "$@"
      ;;
    vertx)
      local script="$REPO_ROOT/poc/java-vertx-distributed/scripts/down.sh"
      if [ -f "$script" ]; then
        _require_script "$script"
        exec "$script" "$@"
      else
        REPO_ROOT="$REPO_ROOT" exec docker compose \
          -f "$REPO_ROOT/compose/docker-compose.yml" \
          -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
          down "$@"
      fi
      ;;
    monolith)
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/java-monolith/compose.override.yml" \
        down "$@"
      ;;
    all)
      REPO_ROOT="$REPO_ROOT" exec docker compose \
        -f "$REPO_ROOT/compose/docker-compose.yml" \
        -f "$REPO_ROOT/poc/java-vertx-distributed/compose.override.yml" \
        -f "$REPO_ROOT/poc/java-monolith/compose.override.yml" \
        down "$@"
      ;;
    compose)
      # backward compat alias
      nx_down vertx "$@"
      ;;
    k8s)
      local script="$REPO_ROOT/poc/k8s-local/scripts/down.sh"
      _require_script "$script"
      exec "$script" "$@"
      ;;
    --help|-h)
      printf 'Usage: ./nx down [infra|vertx|monolith|all|k8s] [--cleanup-k8s]\n'
      exit 0
      ;;
    *)
      _die "Unknown target: $mode. Use: infra, vertx, monolith, all, k8s"
      ;;
  esac
}

nx_status() {
  _info "Docker containers:"
  docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || _warn "docker not available"
  local k8s_script="$REPO_ROOT/poc/k8s-local/scripts/status.sh"
  if [ -f "$k8s_script" ]; then
    _info "K8s pods:"
    bash "$k8s_script" 2>/dev/null || true
  fi
}

nx_logs() {
  local service="${1:-}"
  if [ -z "$service" ]; then
    _die "Usage: ./nx logs <service>"
  fi
  _info "Tailing logs for: $service"
  docker logs -f "$service" 2>/dev/null || _die "Service not found or docker unavailable: $service"
}

# ─── Smart build helpers (see docs/QUICK-REFERENCE.md "Build performance") ────
#
# nx_build_target <target>     incremental, jar-freshness aware build
# _all_jars_fresh <target>     true if jars exist and newer than sources
# _build_lock_acquire <tgt>    coordinate concurrent agents
# _build_lock_release <tgt>
#
# Default: FAST. Forces only if NX_REBUILD=1 or --rebuild. The legacy
# `./gradlew clean build` path is preserved via --legacy-clean for CI/debug.

_nx_lock_dir() { echo "$REPO_ROOT/.gradle/.nx-build-locks"; }

_build_lock_acquire() {
  local target="$1"
  local lock_dir; lock_dir="$(_nx_lock_dir)"
  mkdir -p "$lock_dir"
  local lock="$lock_dir/$target.lock"
  local waited=0
  while true; do
    if ( set -o noclobber; echo "$$" > "$lock" ) 2>/dev/null; then
      return 0
    fi
    local pid; pid="$(cat "$lock" 2>/dev/null || echo "")"
    if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
      _info "[lock] removing stale lock for $target (pid=$pid not alive)"
      rm -f "$lock"
      continue
    fi
    if [[ "${NX_BUILD_NOWAIT:-0}" == "1" ]]; then
      _info "[lock] another build in progress for $target (pid=$pid). Exiting (NX_BUILD_NOWAIT=1)."
      return 2
    fi
    if (( waited % 10 == 0 )); then
      _info "[lock] waiting for in-progress build of $target (pid=$pid)..."
    fi
    sleep 2
    waited=$((waited + 2))
    if (( waited > 600 )); then
      _info "[lock] timeout after 10min, breaking lock"
      rm -f "$lock"
    fi
  done
}

_build_lock_release() {
  local target="$1"
  rm -f "$(_nx_lock_dir)/$target.lock"
}

# Map target → "modules|jar_globs|source_dirs"
# Each field uses ; as separator inside.
_target_spec() {
  case "$1" in
    monolith)
      echo ":poc:java-monolith:shadowJar"
      # ;-separated: REQUIRED artifacts. |-separated within: ALTERNATIVES.
      echo "$REPO_ROOT/poc/java-monolith/build/libs/java-monolith.jar|$REPO_ROOT/poc/java-monolith/build/libs/java-monolith-*-all.jar|$REPO_ROOT/poc/java-monolith/build/libs/java-monolith-*-SNAPSHOT.jar"
      echo "$REPO_ROOT/poc/java-monolith/src;$REPO_ROOT/poc/java-monolith/build.gradle.kts"
      ;;
    vertx)
      echo ":poc:java-vertx-distributed:controller-app:shadowJar :poc:java-vertx-distributed:usecase-app:shadowJar :poc:java-vertx-distributed:repository-app:shadowJar :poc:java-vertx-distributed:consumer-app:shadowJar"
      echo "$REPO_ROOT/poc/java-vertx-distributed/controller-app/build/libs/controller-app-*-all.jar|$REPO_ROOT/poc/java-vertx-distributed/controller-app/build/libs/controller-app-*-SNAPSHOT.jar;$REPO_ROOT/poc/java-vertx-distributed/usecase-app/build/libs/usecase-app-*-all.jar|$REPO_ROOT/poc/java-vertx-distributed/usecase-app/build/libs/usecase-app-*-SNAPSHOT.jar;$REPO_ROOT/poc/java-vertx-distributed/repository-app/build/libs/repository-app-*-all.jar|$REPO_ROOT/poc/java-vertx-distributed/repository-app/build/libs/repository-app-*-SNAPSHOT.jar;$REPO_ROOT/poc/java-vertx-distributed/consumer-app/build/libs/consumer-app-*-all.jar|$REPO_ROOT/poc/java-vertx-distributed/consumer-app/build/libs/consumer-app-*-SNAPSHOT.jar"
      echo "$REPO_ROOT/poc/java-vertx-distributed"
      ;;
    vrp|vertx-platform)
      echo ":poc:vertx-risk-platform:shadowJar"
      echo "$REPO_ROOT/poc/vertx-risk-platform/build/libs/vertx-risk-platform.jar|$REPO_ROOT/poc/vertx-risk-platform/build/libs/vertx-risk-platform-*-all.jar|$REPO_ROOT/poc/vertx-risk-platform/build/libs/vertx-risk-platform-*-SNAPSHOT.jar"
      echo "$REPO_ROOT/poc/vertx-risk-platform/src;$REPO_ROOT/poc/vertx-risk-platform/build.gradle.kts"
      ;;
    bare-javac|risk-engine)
      echo ":poc:java-risk-engine:assemble"
      echo "$REPO_ROOT/poc/java-risk-engine/build/classes"
      echo "$REPO_ROOT/poc/java-risk-engine/src;$REPO_ROOT/poc/java-risk-engine/build.gradle.kts"
      ;;
    bench-distributed)
      echo ":bench:distributed-bench:shadowJar"
      echo "$REPO_ROOT/bench/distributed-bench/build/libs/distributed-bench-*.jar"
      echo "$REPO_ROOT/bench/distributed-bench/src;$REPO_ROOT/bench/distributed-bench/build.gradle.kts"
      ;;
    bench-inprocess)
      echo ":bench:inprocess-bench:shadowJar"
      echo "$REPO_ROOT/bench/inprocess-bench/build/libs/inprocess-bench-*.jar"
      echo "$REPO_ROOT/bench/inprocess-bench/src;$REPO_ROOT/bench/inprocess-bench/build.gradle.kts"
      ;;
    *)
      return 1
      ;;
  esac
}

_first_existing_glob() {
  # Print the first file that matches any of the ;-separated globs. Empty if none.
  local globs="$1"
  local IFS=';'
  read -r -a parts <<<"$globs"
  for g in "${parts[@]}"; do
    # shellcheck disable=SC2086
    for f in $g; do
      if [[ -e "$f" ]]; then
        echo "$f"
        return 0
      fi
    done
  done
  return 1
}

_newest_in() {
  # Print epoch mtime of newest matching file under given dir(s); 0 if none.
  local dirs="$1"
  local IFS=';'
  read -r -a parts <<<"$dirs"
  local newest=0
  for d in "${parts[@]}"; do
    [[ -e "$d" ]] || continue
    local m
    if [[ -d "$d" ]]; then
      m="$(find "$d" \( -name '*.java' -o -name '*.kt' -o -name '*.kts' -o -name '*.gradle' \) -type f -print0 2>/dev/null \
            | xargs -0 stat -f '%m' 2>/dev/null \
            | sort -rn | head -1)"
    else
      m="$(stat -f '%m' "$d" 2>/dev/null || echo 0)"
    fi
    [[ -n "$m" && "$m" -gt "$newest" ]] && newest="$m"
  done
  echo "$newest"
}

_all_jars_fresh() {
  # Spec line 2: ;-separated REQUIRED artifacts. Each artifact may itself be
  # |-separated alternatives (any one matching counts). All artifacts must
  # have at least one existing match. The oldest matched mtime is compared
  # to the newest source mtime.
  local target="$1"
  local spec; spec="$(_target_spec "$target")" || return 1
  local jars_line src_line
  jars_line="$(echo "$spec" | sed -n '2p')"
  src_line="$(echo "$spec"  | sed -n '3p')"

  local jar_oldest=0
  local oldIFS="$IFS"
  IFS=';' read -r -a artifacts <<<"$jars_line"
  IFS="$oldIFS"
  local artifact alt found f m
  for artifact in "${artifacts[@]}"; do
    found=0
    local newest_for_this=0
    IFS='|' read -r -a alts <<<"$artifact"
    IFS="$oldIFS"
    for alt in "${alts[@]}"; do
      # shellcheck disable=SC2206
      local matches=( $alt )
      for f in "${matches[@]}"; do
        if [[ -e "$f" ]]; then
          found=1
          m="$(stat -f '%m' "$f" 2>/dev/null || echo 0)"
          [[ "$m" -gt "$newest_for_this" ]] && newest_for_this="$m"
        fi
      done
    done
    [[ $found -eq 0 ]] && return 1
    # Use newest match across alternatives as this artifact's mtime
    if [[ "$jar_oldest" == 0 || "$newest_for_this" -lt "$jar_oldest" ]]; then
      jar_oldest="$newest_for_this"
    fi
  done

  local newest_src; newest_src="$(_newest_in "$src_line")"
  if [[ "$newest_src" -gt "$jar_oldest" ]]; then
    return 1
  fi
  return 0
}

nx_build_target() {
  local target="$1"
  local force_rebuild="${NX_REBUILD:-0}"
  shift || true
  for arg in "$@"; do
    [[ "$arg" == "--rebuild" || "$arg" == "--force-rebuild" ]] && force_rebuild=1
  done

  local spec
  if ! spec="$(_target_spec "$target")"; then
    _die "Unknown build target: $target. Use: monolith | vertx | vrp | bare-javac | bench-distributed | bench-inprocess"
  fi
  local modules; modules="$(echo "$spec" | sed -n '1p')"

  if [[ "$force_rebuild" == "0" ]] && _all_jars_fresh "$target"; then
    _info "[build:$target] up-to-date (use --rebuild or NX_REBUILD=1 to force)"
    return 0
  fi

  if ! _build_lock_acquire "$target"; then
    return 0
  fi
  trap "_build_lock_release '$target'" EXIT INT TERM

  if [[ "$force_rebuild" == "1" ]]; then
    _info "[build:$target] FORCED rebuild — running clean before assemble"
    # shellcheck disable=SC2086
    "$REPO_ROOT/gradlew" -p "$REPO_ROOT" $(echo "$modules" | sed 's/:shadowJar/:clean/g; s/:assemble/:clean/g') --no-daemon=false || true
  fi

  # configuration-cache is opt-in (NX_CONFIG_CACHE=1) — some subprojects don't
  # support it cleanly yet. build-cache + parallel are always safe.
  local extra_flags="--build-cache --parallel"
  [[ "${NX_CONFIG_CACHE:-0}" == "1" ]] && extra_flags="$extra_flags --configuration-cache"
  _info "[build:$target] gradlew $modules $extra_flags"
  # shellcheck disable=SC2086
  "$REPO_ROOT/gradlew" -p "$REPO_ROOT" $modules $extra_flags
  local rc=$?
  _build_lock_release "$target"
  trap - EXIT INT TERM
  return $rc
}

nx_build() {
  # Backward compat:
  #   ./nx build                  → incremental assemble of all known targets
  #   ./nx build <target>         → smart per-target build
  #   ./nx build --legacy-clean   → original `./gradlew clean build`
  #   ./nx build --rebuild        → forced rebuild of all targets
  local first="${1:-}"
  case "$first" in
    --legacy-clean)
      shift
      _info "Running legacy ./gradlew clean build (slow path)..."
      exec "$REPO_ROOT/gradlew" -p "$REPO_ROOT" clean build "$@"
      ;;
    monolith|vertx|vrp|vertx-platform|bare-javac|risk-engine|bench-distributed|bench-inprocess)
      nx_build_target "$@"
      ;;
    ""|--rebuild|--force-rebuild|all)
      [[ "$first" == "--rebuild" || "$first" == "--force-rebuild" ]] && export NX_REBUILD=1
      _info "[build] incremental build of all targets (set --rebuild for clean)"
      local rc=0
      for t in monolith vertx vrp bench-distributed bench-inprocess; do
        nx_build_target "$t" || rc=$?
      done
      return $rc
      ;;
    -h|--help)
